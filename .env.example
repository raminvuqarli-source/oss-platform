# ═══════════════════════════════════════════════════════
#  O.S.S Smart Hotel System — Production Environment
#  Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════

# ─── REQUIRED ─────────────────────────────────────────

# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://ossuser:strongpassword@db:5432/oss_db

# Session cookie encryption key (minimum 32 characters, use a random string)
SESSION_SECRET=generate-a-random-64-character-string-here

# Application mode (keep as production on VPS)
NODE_ENV=production

# Server port
PORT=5000

# ─── APP URL ──────────────────────────────────────────

# Full URL where your app is accessible (used for email links, OAuth, etc.)
APP_BASE_URL=https://yourdomain.com
BASE_URL=https://yourdomain.com

# ─── EMAIL (Resend) ───────────────────────────────────

# Get your API key from https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=noreply@yourdomain.com

# ─── PAYMENT (Epoint — Azerbaijan payment gateway) ────

EPOINT_MERCHANT_ID=your-epoint-merchant-id
EPOINT_PRIVATE_KEY=your-epoint-private-key
EPOINT_PUBLIC_KEY=your-epoint-public-key

# ─── PAYMENT (Payriff — optional) ────────────────────

PAYRIFF_MERCHANT_ID=your-payriff-merchant-id
PAYRIFF_SECRET_KEY=your-payriff-secret-key

# ─── PAYMENT (Stripe — optional) ─────────────────────

STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxxxxxxxxx

# ─── PUSH NOTIFICATIONS (OneSignal) ──────────────────

# Get from https://onesignal.com
VITE_ONESIGNAL_APP_ID=your-onesignal-app-id
ONESIGNAL_REST_API_KEY=your-onesignal-rest-api-key

# ─── OPTIONAL ─────────────────────────────────────────

# Error tracking (Sentry) — leave empty to disable
SENTRY_DSN=

# Log level: info | warn | error | debug
LOG_LEVEL=info
