# ═══════════════════════════════════════════════════════
#  O.S.S Smart Hotel System — Production Environment
#  Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════

# ─── REQUIRED ─────────────────────────────────────────

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/oss_db

# Session cookie encryption key (minimum 32 characters)
SESSION_SECRET=generate-a-random-64-character-string-here

# Application mode
NODE_ENV=production

# Server port
PORT=5000

# ─── EMAIL (Resend) ──────────────────────────────────

RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=noreply@ossaiproapp.com

# ─── PAYMENT (Epoint) ────────────────────────────────

EPOINT_MERCHANT_ID=your-epoint-merchant-id
EPOINT_PRIVATE_KEY=your-epoint-private-key
EPOINT_PUBLIC_KEY=your-epoint-public-key

# ─── PUSH NOTIFICATIONS (OneSignal) ──────────────────

VITE_ONESIGNAL_APP_ID=your-onesignal-app-id
ONESIGNAL_REST_API_KEY=your-onesignal-rest-api-key

# ─── APP URL ──────────────────────────────────────────

APP_BASE_URL=https://ossaiproapp.com

# ─── OPTIONAL ─────────────────────────────────────────

# Error tracking
SENTRY_DSN=

# Log level (info, warn, error, debug)
LOG_LEVEL=info
