# ═══════════════════════════════════════════════════════
#  O.S.S Smart Hotel System — Production Environment
#  1. Bu faylı kopyalayın: cp .env.example .env
#  2. Aşağıdakı dəyərləri doldurun
# ═══════════════════════════════════════════════════════

# ─── VERİTABANI ───────────────────────────────────────
# docker-compose.yml ilə uyğundur — dəyişdirməyin
DATABASE_URL=postgresql://oss:osspassword@postgres:5432/ossdb

# ─── SESSION ──────────────────────────────────────────
# Ən azı 32 simvol — random string yazın
SESSION_SECRET=generate-a-very-long-random-secret-string-here-min-32chars

# ─── REJIM ────────────────────────────────────────────
NODE_ENV=production
PORT=5000

# ─── APP URL ──────────────────────────────────────────
# Saytın tam ünvanı (email linkləri üçün)
APP_BASE_URL=https://yourdomain.com
BASE_URL=https://yourdomain.com

# ─── EMAIL (Resend) ───────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=noreply@yourdomain.com

# ─── ÖDƏMƏ (Epoint — Azərbaycan) ─────────────────────
EPOINT_MERCHANT_ID=your-epoint-merchant-id
EPOINT_PRIVATE_KEY=your-epoint-private-key
EPOINT_PUBLIC_KEY=your-epoint-public-key

# ─── ÖDƏMƏ (Payriff — ixtiyari) ──────────────────────
PAYRIFF_MERCHANT_ID=your-payriff-merchant-id
PAYRIFF_SECRET_KEY=your-payriff-secret-key

# ─── ÖDƏMƏ (Stripe — ixtiyari) ───────────────────────
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxxxxxxxxx

# ─── BİLDİRİŞ (OneSignal — ixtiyari) ────────────────
VITE_ONESIGNAL_APP_ID=your-onesignal-app-id
ONESIGNAL_REST_API_KEY=your-onesignal-rest-api-key

# ─── LOG ──────────────────────────────────────────────
LOG_LEVEL=info
SENTRY_DSN=
